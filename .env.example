# AI Employee - Environment Variables Template
# Copy this file to .env and fill in your credentials
# NEVER commit .env to git!

# ==================== GMAIL CONFIGURATION ====================
GMAIL_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password

# Get Gmail App Password:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Create app password for "Mail"
# 3. Copy 16-character password here

# ==================== LINKEDIN CREDENTIALS ====================
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# ==================== TWITTER API (Optional) ====================
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# Get Twitter API credentials:
# https://developer.twitter.com/en/portal/dashboard

# ==================== FACEBOOK/INSTAGRAM (Optional) ====================
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Get Facebook credentials:
# https://developers.facebook.com/apps/

# ==================== ODOO ACCOUNTING (Optional) ====================
ODOO_URL=http://localhost:8069
ODOO_DB=ai_employee_accounting
ODOO_USERNAME=admin
ODOO_PASSWORD=your_odoo_password

# Install Odoo: See AI_Employee_Vault/ODOO_SETUP_GUIDE.md

# ==================== VAULT PATH ====================
VAULT_PATH=E:\AI-300\My_Hackathons_Teacher\AI_Employee_Vault

# Adjust path based on your installation location
